PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=tattoo-machines

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_REFRESH_LONG=30d

# Cookies
COOKIE_SECRET=

# Frontend (Netlify URL or custom domain)
CLIENT_ORIGIN=https://your-app.netlify.app

# API public URL (for WayForPay callbacks and email links)
API_BASE_URL=https://your-api-domain.com/api/v1

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_PROJECT=tattoo-store

# WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_DOMAIN_NAME=
